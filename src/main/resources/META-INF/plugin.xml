<idea-plugin require-restart="false">
    <id>net.lsafer.ij.fun_file_icon</id>
    <name>Kotlin Function File Icon</name>
    <vendor>LSafer</vendor>

    <description><![CDATA[
        Change the icon of a Kotlin file when it has a toplevel function with the same name as the file.
    ]]></description>

    <change-notes>
        Initial Version
    </change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <iconProvider implementation="net.lsafer.ij.fun_file_icon.FunFileIconProvider" order="first"/>
    </extensions>
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="true" supportsK2="true"/>
    </extensions>
</idea-plugin>
